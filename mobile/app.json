{
  "expo": {
    "name": "budgetr",
    "slug": "budgetr-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "budgetr",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "dev.budgetr.companion",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.dev.budgetr.companion",
          "group.dev.budgetr.companion"
        ]
      },
      "appleTeamId": "B9UFFWUAD8"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080b0a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "budgetr uses the camera only to scan your Mac's pairing code."
        }
      ],
      "expo-font",
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "dev.budgetr.companion.widget",
                  "targetName": "budgetr",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.dev.budgetr.companion"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "52b279d8-2c7f-400f-a4e0-3123bf1a4507"
      }
    },
    "owner": "kgeees-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/52b279d8-2c7f-400f-a4e0-3123bf1a4507"
    }
  }
}
