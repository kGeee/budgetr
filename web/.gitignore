# Self-contained so web/ stays safe even if extracted into its own repo.
# (The monorepo root .gitignore covers these too while web/ lives here.)

# dependencies
node_modules/
# private Node.js copy downloaded by start.sh for non-developers
.node-runtime/

# next.js / typescript
.next/
out/
*.tsbuildinfo
next-env.d.ts

# env files — never commit secrets (env.example is the committed template)
.env*

# local data (SQLite DB, receipts) — real financial data lives here
data/
*.db
*.db-shm
*.db-wal

# testing
coverage/

# misc
.DS_Store
*.pem
npm-debug.log*

# Electron desktop build artifacts
/dist/
/desktop/build/icon.icns
