{
  "name": "budgetr",
  "version": "0.5.1",
  "private": true,
  "description": "budgetr — personal finance, self-hosted",
  "author": "budgetr",
  "main": "desktop/electron/main.js",
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "node scripts/run-next.mjs build",
    "start": "node scripts/run-next.mjs start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "tsx --env-file-if-exists=.env.local scripts/setup.ts",
    "dev:electron": "npm run web:rebuild && electron desktop/electron/main.js",
    "package": "npm run web:rebuild && next build --webpack && bash desktop/scripts/make-icns.sh && npm run electron:rebuild && CSC_IDENTITY_AUTO_DISCOVERY=${CSC_IDENTITY_AUTO_DISCOVERY:-false} electron-builder --mac --publish never",
    "electron:rebuild": "electron-rebuild -f -o better-sqlite3",
    "web:rebuild": "npm rebuild better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file-if-exists=.env.local scripts/seed-categories.ts",
    "db:reset-items": "tsx --env-file-if-exists=.env.local scripts/reset-items.ts",
    "db:studio": "drizzle-kit studio",
    "sync": "tsx --env-file-if-exists=.env.local scripts/sync.ts"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@budgetr/core": "file:../packages/core",
    "@budgetr/sync-crypto": "file:../packages/sync-crypto",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "papaparse": "^5.5.4",
    "plaid": "^42.2.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.5.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "dev.budgetr.app",
    "productName": "budgetr",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "desktop/build"
    },
    "files": [
      "desktop/electron/**/*",
      ".next/**/*",
      "!.next/cache/**",
      "public/**/*",
      "db/**/*",
      "next.config.ts",
      "package.json"
    ],
    "afterPack": "desktop/scripts/afterpack-sign.js",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.finance",
      "icon": "desktop/build/icon.icns",
      "artifactName": "budgetr-mac.${ext}",
      "hardenedRuntime": true,
      "notarize": true
    },
    "dmg": {
      "title": "budgetr",
      "artifactName": "budgetr-mac.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "kGeee",
      "repo": "budgetr"
    }
  }
}
